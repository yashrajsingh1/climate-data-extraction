# Climate Data Extraction System - Environment Configuration

# Database Configuration
DB_URL=sqlite:///./data/climate_data.db
# For PostgreSQL: DB_URL=postgresql://user:password@localhost:5432/climate_data
DB_ECHO=false
DB_POOL_SIZE=5

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# Extraction Configuration
EXTRACT_USE_LLM_FALLBACK=true
EXTRACT_LLM_TRIGGER_THRESHOLD=0.5
EXTRACT_MAX_PDF_SIZE_MB=50
EXTRACT_MAX_PAGES_PER_PDF=500

# Discovery Configuration
DISCOVERY_REQUESTS_PER_MINUTE=30
DISCOVERY_RETRY_ATTEMPTS=3
DISCOVERY_MAX_RESULTS_PER_SOURCE=10

# Storage Configuration
STORAGE_RAW_DATA_PATH=./data/raw
STORAGE_PROCESSED_DATA_PATH=./data/processed
STORAGE_REPORTS_PATH=./data/reports
